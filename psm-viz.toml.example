# psm-viz runtime config
#
# Relative paths resolve relative to this file.

session_dir = "./session"
# video_path = "./session/video.mp4"
# features_path = "./session/features.h5"

group = "dino"
time_window_sec = 5.0
h3_resolution = 10
start_paused = true
debug_hud_enabled = true
scrub_sensitivity_sec = 2.0
map_follow_smoothing = 8.0
# Baseline per-frame budgets. The runtime may temporarily boost these above the
# configured values when it detects sustained backlog, then decay back down.
video_decode_budget = 6
ingest_record_budget = 128
imu_sample_budget = 512
gps_point_budget = 64
# Baseline upload budget for decoded raster tiles.
tile_uploads_per_frame = 1
tile_disk_cache_enabled = true
tile_disk_cache_max_mb = 512
heatmap_mode = "total"

# Available tile_style presets:
#   CartoDB.Positron
#   CartoDB.PositronNoLabels
#   CartoDB.Voyager
#   CartoDB.DarkMatter
#   Stadia.AlidadeSmooth
#   Stadia.AlidadeSmoothDark
tile_style = "CartoDB.Positron"

# Required for Stadia.* presets or any custom template using {api_key}.
# tile_api_key = "your-api-key"

# Optional custom URL override. Supports {z}, {x}, {y}, {s}, and {api_key}.
# When set, this takes precedence over tile_style.
# tile_url_template = "https://tile.openstreetmap.org/{z}/{x}/{y}.png"

# Heatmap modes:
#   total    -> rolling merged count across the full ring buffer
#   current  -> current time bucket only
#   recency  -> current / total
# Press M at runtime to cycle modes.

# See configs/ for ready-made presets such as psm-viz-balanced.toml and
# psm-viz-low-hitch.toml.
